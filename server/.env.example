PORT=3001
DB_PATH=./data/signi.sqlite

# Public site origin — used to build absolute URLs (RSS, canonical).
SITE_URL=https://signi.com

# Transactional email (Resend). Without RESEND_API_KEY, form mail is logged,
# not sent — the form flow still works for local development.
RESEND_API_KEY=
MAIL_FROM=Signi <noreply@signi.com>
SALES_INBOX=sales@signi.com

# Cloudflare Turnstile — optional. When TURNSTILE_SECRET is set, the form
# endpoint verifies the token; otherwise honeypot + rate-limit alone apply.
TURNSTILE_SECRET=
