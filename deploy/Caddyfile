# signi-web — Caddy routing.
#
# This is a snippet, not a standalone Caddyfile. The blocks below go INSIDE the
# existing `dev.signi.com { ... }` site block on the VPS, alongside the other
# prototypes' handles and before the trailing `file_server`.
#
# Layout on the VPS:
#   /var/www/dev/prototypes/signi-web/        Astro static site
#   /var/www/dev/prototypes/signi-web/admin/  admin panel SPA
#   /srv/signi-web-cms/                       Fastify CMS (systemd: signi-cms, :8788)
#
# The Fastify app runs with BASE_PATH=/prototypes/signi-web, so its routes
# already include the prefix — the reverse_proxy must NOT strip it. The static
# Astro site is plain files served by the dev.signi.com block's trailing
# `file_server`, so it needs no handle of its own.

	# signi-web CMS backend (blog SSR + API) → Node service on 127.0.0.1:8788
	@signi-web-api path /prototypes/signi-web/api/* /prototypes/signi-web/blog/* /prototypes/signi-web/category/* /prototypes/signi-web/uploads/*
	handle @signi-web-api {
		reverse_proxy 127.0.0.1:8788
	}

	# signi-web admin panel — SPA fallback (try_files rewrites; file_server serves)
	@signi-web-admin path /prototypes/signi-web/admin/*
	handle @signi-web-admin {
		try_files {path} /prototypes/signi-web/admin/index.html
	}

# --- Production (signi.com) ----------------------------------------------
# At the production root BASE_PATH is empty. A dedicated signi.com site block
# proxies /api/*, /blog/*, /category/*, /uploads/* to the CMS, serves /admin/*
# as the SPA, imports deploy/redirects.caddy, and keeps /wp-content/uploads/*
# resolving (see deploy/README.md).
