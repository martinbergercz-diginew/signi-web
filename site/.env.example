# Build-time deployment config for the public Astro site.
# The deploy script passes these inline; copy to .env for local overrides.
#
#   production root        — BASE_PATH= (empty),  SITE_URL=https://signi.com
#   dev.signi.com staging  — BASE_PATH=/prototypes/signi-web,
#                            SITE_URL=https://dev.signi.com
BASE_PATH=
SITE_URL=https://signi.com
