---
import { strings, homePath, LANGS } from '../i18n/strings.js';
import { url } from '../lib/url.js';

interface Props {
  lang?: string;
}
const { lang = 'cs' } = Astro.props;
const t = strings[lang] ?? strings.cs;
const helpLabel = { cs: 'Nápověda', en: 'Help', sk: 'Nápoveda', hu: 'Súgó' }[lang] ?? 'Nápověda';
---

<div class="topbar">
  <div class="container topbar__inner">
    <a href="https://helpdesk.signi.com">{helpLabel}</a>
    <span>Obchodní oddělení: +420 222 260 888</span>
    <span>Podpora: help@signi.com</span>
    <a href={url(t.login.href)}>{t.login.label}</a>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand-logo" href={url(homePath[lang])}>
      <img src={url('/img/logo.svg')} alt="Signi.com" />
    </a>

    <nav class="site-nav" aria-label="Hlavní navigace">
      {t.nav.map((item) => <a href={url(item.href)}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <div class="lang-switch" aria-label="Jazyk">
        {LANGS.map((l) => (
          <a href={url(homePath[l])} aria-current={l === lang ? 'true' : 'false'}>
            {l.toUpperCase()}
          </a>
        ))}
      </div>
      <a class="btn btn--ghost" href={url(t.ctaDemo.href)}>{t.ctaDemo.label}</a>
      <a class="btn btn--primary" href={url(t.ctaTry.href)}>{t.ctaTry.label}</a>
    </div>
  </div>
</header>
