---
import { strings } from '../i18n/strings.js';

interface Props {
  lang?: string;
}
const { lang = 'cs' } = Astro.props;
const t = strings[lang] ?? strings.cs;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-cols">
      <div>
        <div class="brand-logo" style="color:#fff">Signi</div>
        <p style="margin-top:14px">{t.footer.tagline}</p>
      </div>
      {t.footer.cols.map((col) => (
        <div>
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>© {year} {t.footer.legal}</span>
      <span>info@signi.com</span>
    </div>
  </div>
</footer>
