---
import Base from '../layouts/Base.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { homeAlternates } from '../i18n/strings.js';

const reasons = [
  ['Právní závaznost podepsaných dokumentů', 'Papírování patří minulosti. Stejně jako kulaté razítko. Elektronický podpis v Signi má stejnou váhu jako ten na papíře a je právně závazný.'],
  ['Rychlejší jednání se zákazníky a zaměstnanci', 'Kupní smlouvy, objednávky, dohody o provedení práce a desítky dalších dokumentů odbavíte online. Vaši zákazníci i zaměstnanci to ocení.'],
  ['Jednodušší firemní administrativa', 'Digitální dokumenty nemusíte tisknout, shánět na ně podpisy, ani je skenovat již podepsané. Vše zařídíte pohodlně ze svého počítače, na pár kliknutí.'],
  ['Trvalá kontrola nad obchodní dokumentací', 'Všechny vaše smlouvy a jiné firemní dokumenty se bezpečně ukládají na jednom místě a můžete k nim přistupovat online 24/7.'],
  ['Nižší náklady na skladování dokumentů', 'Elektronický archiv nezatěžuje firemní kapsu, ani police ve skladu. Signi úložiště je bezpečné a přehledné. Snadno v něm hledáte i filtrujete.'],
  ['Ekologická a finanční úspora na spotřebním materiálu', 'Každá nevytištěná stránka se počítá. Nižší spotřeba papíru a tonerů potěší vás i přírodu. Výdaje za provoz vašeho tiskového parku se citelně sníží.'],
];

const features = [
  ['Elektronický podpis a vzdálená identifikace na jednom zařízení', 'Digitální podpisy Signi jsou v souladu s normou eIDAS a platí v celé Evropské unii. Pro vzdálené ověřování identity používáme BankID nebo Signi identifikaci.'],
  ['Automatizovaná workflow pro rychlejší práci s dokumenty', 'Podepisování a schvalování dokumentů probíhá na pár kliknutí. Sami si nastavíte sofistikované workflow, které podpisy, termíny i hladký průběh schvalování hlídá za vás.'],
  ['Rychlá integrace do systémů, které již používáte', 'K propojení na vaše interní systémy nepotřebujeme dlouhé měsíce. Máme hotové API i konektory pro různé typy CRM, DMS i ERP systémů — integrujeme v řádu dnů až týdnů.'],
  ['Bezpečné řešení pro banky, korporace i startupy', 'Vaše data jsou u nás v bezpečí. Všechny procesy monitorujeme 24/7 a pravidelně provádíme penetrační a zátěžové testy. Ručíme za ně i certifikacemi ISO 27001 a 27017.'],
];

const cases = [
  ['QI', 'QI a digitalizace výroby s podpisem od Signi'],
  ['Alza.cz', 'Digitální podepisování od Signi zefektivnilo administrativní procesy v Alza.cz'],
  ['Packeta Group', 'Reklamační proces v Zásilkovně i v celé Packeta Group probíhá díky Signi plně digitálně'],
];

const partners = [
  ['Onboarding', 'Poradíme vám, jak začít s digitalizací ve vaší firmě. Od technického nastavení po proškolení zaměstnanců.'],
  ['Péče o klienty', 'Budeme váš průvodce na cestě k digitalizaci. O digitálním podpisu víme téměř vše a rádi vám poradíme.'],
  ['Technická podpora', 'Máte technický problém nebo požadavek? Nahlédněte do nápovědy nebo se na nás obraťte. Rádi vám poradíme.'],
  ['Webináře', 'Pravidelně pořádáme webináře plné praktických zkušeností a novinek ze světa digitálního podepisování.'],
  ['Případové studie', 'Inspirujte se příběhy firem, které úspěšně digitalizovaly firemní dokumenty a zbavily se administrativy.'],
  ['Ke stažení', 'Vše důležité o digitálním podepisování. Doporučujeme náš nejstahovanější dokument 40 HR dokumentů.'],
];
---

<Base
  title="Elektronický podpis dokumentů | Signi"
  description="Zrychlujeme váš byznys. Online elektronický podpis závazných dokumentů i smluv je se Signi otázkou pár minut. Vytvořte i podepište cokoliv a kdekoliv."
  lang="cs"
  alternates={homeAlternates}
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">Elektronický podpis dokumentů</span>
      <h1>Signi je vše, co potřebujete, abyste se dohodli</h1>
      <p class="lead">
        Digitalizovat můžete dnes 100 % dokumentů a procesů. Dokumenty vytvoříte,
        schválíte, podepíšete a archivujete. Vše elektronicky a v jedné aplikaci.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="https://app.signi.com/register">Vyzkoušet zdarma</a>
        <a class="btn btn--ghost" href="/odeslat-poptavku/">Domluvit prezentaci</a>
      </div>
      <p style="margin-top:28px;color:var(--muted);font-size:.95rem">
        Důvěřují nám lidé z více než 2 000 inovativních firem.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__head section__head--center">
        <span class="eyebrow">Proč Signi</span>
        <h2>6 důvodů proč přejít na elektronické podepisování dokumentů</h2>
        <p class="lead">
          Online podpis smluv a dalších firemních dokumentů šetří čas, snižuje
          náklady na tisk a minimalizuje chybovost.
        </p>
      </div>
      <div class="grid grid--3">
        {reasons.map(([title, text], i) => (
          <div class="card">
            <div class="card__icon">{i + 1}</div>
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">Co Signi umí</span>
        <h2>Vše, co od digitálního podepisování čekáte</h2>
      </div>
      <div class="grid grid--2">
        {features.map(([title, text]) => (
          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">Případové studie</span>
        <h2>Články</h2>
        <p class="lead">
          Firmy už nechtěly mít svůj byznys zatížený zbytečnou administrativou.
          Proto se rozhodly, že digitalizují se Signi.
        </p>
      </div>
      <div class="grid grid--3">
        {cases.map(([tag, title]) => (
          <div class="card">
            <span class="eyebrow">{tag}</span>
            <h3>{title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head section__head--center">
        <h2>Jsme vaši partneři na cestě k digitalizaci</h2>
      </div>
      <div class="grid grid--3">
        {partners.map(([title, text]) => (
          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    lang="cs"
    title="Zefektivněte firemní procesy a převeďte 100 % podepisování do Signi"
    text="Vyzkoušejte si Signi zdarma a nezávazně, nebo si s námi domluvte prezentaci."
  />
</Base>
