---
import Base from '../layouts/Base.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { homeAlternates } from '../i18n/strings.js';
import { url } from '../lib/url.js';

const checklist = [
  ['Elektronický podpis', 'Pro každý dokument máme ten správný elektronický podpis. Proto se bez obav můžete zbavit papírování.'],
  ['Důvěryhodná archivace', 'Stejně důležité jako uzavření smlouvy je i její důvěryhodná archivace, která vám zajistí platnost po desítky let.'],
  ['Vzdálená identifikace', 'Onboarding i uzavření smlouvy se zákazníkem je se Signi bezpečné, automatizované a hotové během pár minut.'],
  ['Schvalovací a podpisové workflow', 'Eliminujte zbytečné čekání a zdlouhavé schvalování papírových dokumentů. Digitalizujte a zjednodušte si práci.'],
];

const trust = ['trust-1.png', 'trust-2.png', 'trust-3.png', 'trust-4.png', 'trust-5.png', 'trust-6.png'];

const reasons = [
  ['reason-1.svg', 'Právní závaznost podepsaných dokumentů', 'Papírování patří minulosti. Stejně jako kulaté razítko. Elektronický podpis v Signi má stejnou váhu jako ten na papíře a je právně závazný.'],
  ['reason-2.svg', 'Rychlejší jednání se zákazníky a zaměstnanci', 'Kupní smlouvy, objednávky, dohody o provedení práce a desítky dalších dokumentů odbavíte online. Vaši zákazníci i zaměstnanci to ocení.'],
  ['reason-3.svg', 'Jednodušší firemní administrativa', 'Digitální dokumenty nemusíte tisknout, shánět na ně podpisy, ani je skenovat. Vše zařídíte pohodlně ze svého počítače, na pár kliknutí.'],
  ['reason-4.svg', 'Trvalá kontrola nad obchodní dokumentací', 'Všechny vaše smlouvy a jiné firemní dokumenty se bezpečně ukládají na jednom místě a můžete k nim přistupovat online 24/7.'],
  ['reason-5.svg', 'Nižší náklady na skladování dokumentů', 'Elektronický archiv nezatěžuje firemní kapsu, ani police ve skladu. Signi úložiště je bezpečné a přehledné. Snadno v něm hledáte i filtrujete.'],
  ['reason-6.svg', 'Ekologická a finanční úspora na spotřebním materiálu', 'Každá nevytištěná stránka se počítá. Nižší spotřeba papíru a tonerů potěší vás i přírodu. Výdaje za tiskový park se citelně sníží.'],
];

const features = [
  {
    img: 'feature-podpis.png', rev: false,
    title: 'Elektronický podpis a vzdálená identifikace na jednom zařízení',
    text: 'Digitální podpisy Signi jsou v souladu s normou eIDAS a platí v celé Evropské unii. Pro vzdálené ověřování identity používáme BankID nebo Signi identifikaci.',
  },
  {
    img: 'feature-workflow.png', rev: true,
    title: 'Automatizovaná workflow pro rychlejší práci s dokumenty',
    text: 'Podepisování a schvalování dokumentů probíhá na pár kliknutí. Sami si nastavíte sofistikované workflow, které podpisy, termíny i hladký průběh schvalování hlídá za vás.',
  },
  {
    img: 'integrace.png', rev: false,
    title: 'Rychlá integrace do systémů, které již používáte',
    text: 'Máme hotové API i konektory pro různé typy CRM, DMS i ERP systémů — Signi integrujeme v řádu dnů až týdnů, ne měsíců.',
  },
];

const partners = [
  ['partner-1.png', 'Onboarding', 'Poradíme vám, jak začít s digitalizací ve vaší firmě. Od technického nastavení po proškolení zaměstnanců.'],
  ['partner-2.png', 'Péče o klienty', 'Budeme váš průvodce na cestě k digitalizaci. O digitálním podpisu víme téměř vše a rádi vám poradíme.'],
  ['partner-3.png', 'Technická podpora', 'Máte technický problém nebo požadavek? Nahlédněte do nápovědy nebo se na nás obraťte. Rádi vám poradíme.'],
  ['partner-4.png', 'Webináře', 'Pravidelně pořádáme webináře plné praktických zkušeností a novinek ze světa digitálního podepisování.'],
  ['partner-5.png', 'Případové studie', 'Inspirujte se příběhy firem, které úspěšně digitalizovaly firemní dokumenty a zbavily se administrativy.'],
  ['partner-6.png', 'Ke stažení', 'Vše důležité o digitálním podepisování. Doporučujeme náš nejstahovanější dokument 40 HR dokumentů.'],
];
---

<Base
  title="Elektronický podpis dokumentů | Signi"
  description="Zrychlujeme váš byznys. Online elektronický podpis závazných dokumentů i smluv je se Signi otázkou pár minut. Vytvořte i podepište cokoliv a kdekoliv."
  lang="cs"
  alternates={homeAlternates}
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">Elektronický podpis dokumentů</span>
      <h1>Signi je vše, co potřebujete, abyste se dohodli</h1>
      <div class="accent-underline"></div>
      <p class="lead">
        Digitalizovat můžete dnes 100 % dokumentů a procesů. Dokumenty vytvoříte,
        schválíte, podepíšete a archivujete. Vše elektronicky a v jedné aplikaci.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="https://app.signi.com/register">Vyzkoušet zdarma</a>
        <a class="btn btn--ghost" href={url('/odeslat-poptavku/')}>Domluvit prezentaci</a>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:32px">
    <div class="container">
      <div class="showcase">
        <img class="showcase__img" src={url('/img/hero.png')} alt="Aplikace Signi" width="900" height="700" />
        <div class="checklist">
          {checklist.map(([title, text]) => (
            <div class="check-item">
              <svg viewBox="0 0 28 28" aria-hidden="true">
                <circle cx="14" cy="14" r="14" fill="#39e88d" />
                <path d="M8 14.5l4 4 8-9" fill="none" stroke="#fff" stroke-width="2.6"
                      stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div>
                <h3>{title}</h3>
                <p>{text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container trust">
      <p class="trust__label">Důvěřují nám lidé z více než 2 000 inovativních firem.</p>
      <div class="logo-strip">
        {trust.map((logo) => <img src={url(`/img/${logo}`)} alt="" loading="lazy" />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head section__head--center">
        <span class="eyebrow">Proč Signi</span>
        <h2>6 důvodů proč přejít na elektronické podepisování dokumentů</h2>
        <p class="lead">
          Online podpis smluv a dalších firemních dokumentů šetří čas, snižuje
          náklady na tisk a minimalizuje chybovost.
        </p>
      </div>
      <div class="grid grid--3">
        {reasons.map(([icon, title, text]) => (
          <div class="card">
            <div class="icon-tile"><img src={url(`/img/${icon}`)} alt="" /></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__head section__head--center">
        <span class="eyebrow">Co Signi umí</span>
        <h2>Vše, co od digitálního podepisování čekáte</h2>
      </div>
      {features.map((f) => (
        <div class={f.rev ? 'feature-row feature-row--rev' : 'feature-row'}>
          <img class="feature-row__img" src={url(`/img/${f.img}`)} alt="" loading="lazy" />
          <div class="feature-row__text">
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head section__head--center">
        <h2>Jsme vaši partneři na cestě k digitalizaci</h2>
      </div>
      <div class="grid grid--3">
        {partners.map(([icon, title, text]) => (
          <div class="card">
            <div class="icon-tile"><img src={url(`/img/${icon}`)} alt="" /></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <span class="eyebrow">Případové studie</span>
        <h2>Inspirujte se firmami, které už digitalizovaly</h2>
      </div>
      <div class="grid grid--3">
        <article class="card" style="padding:0;overflow:hidden">
          <img src={url('/img/case-qi.png')} alt="" loading="lazy"
               style="width:100%;aspect-ratio:2/1;object-fit:cover" />
          <div style="padding:28px">
            <h3>QI a digitalizace výroby s podpisem od Signi</h3>
          </div>
        </article>
        <article class="card" style="padding:0;overflow:hidden">
          <img src={url('/img/case-alza.jpg')} alt="" loading="lazy"
               style="width:100%;aspect-ratio:2/1;object-fit:cover" />
          <div style="padding:28px">
            <h3>Digitální podepisování od Signi zefektivnilo procesy v Alza.cz</h3>
          </div>
        </article>
        <article class="card">
          <h3>Reklamační proces v Zásilkovně i celé Packeta Group probíhá díky Signi plně digitálně</h3>
        </article>
      </div>
    </div>
  </section>

  <CtaBanner
    lang="cs"
    title="Zefektivněte firemní procesy a převeďte 100 % podepisování do Signi"
    text="Vyzkoušejte si Signi zdarma a nezávazně, nebo si s námi domluvte prezentaci."
  />
</Base>
