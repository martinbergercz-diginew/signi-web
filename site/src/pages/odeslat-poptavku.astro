---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url.js';
---

<Base
  title="Domluvit prezentaci | Signi"
  description="Máte jakýkoliv dotaz? Nechte nám na sebe kontakt. V krátkém čase vás bude kontaktovat náš specialista na elektronický podpis a další služby od Signi."
  lang="cs"
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">Domluvit prezentaci</span>
      <h1>Jste tak blízko. Vyplňte formulář a ostatní zařídíme my</h1>
      <p class="lead">
        Nechte nám na sebe kontakt a v krátkém čase vás bude kontaktovat náš
        specialista na elektronický podpis.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <div>
          <h2>Co od nás můžete čekat</h2>
          <ul class="prose">
            <li>Ozveme se vám do druhého pracovního dne.</li>
            <li>Ukážeme vám Signi na vašich reálných dokumentech.</li>
            <li>Pošleme případové studie firem podobných té vaší.</li>
            <li>Spočítáme cenu na míru velikosti vašeho týmu.</li>
          </ul>
        </div>
        <div class="card">
          <form method="post" action={url('/api/forms')} class="stack">
            <input type="hidden" name="form_type" value="poptavka" />
            <input type="hidden" name="lang" value="cs" />
            {/* Honeypot — hidden from people, bots fill it and get silently dropped. */}
            <div class="hp" aria-hidden="true">
              <label for="website">Web</label>
              <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
            </div>
            <div>
              <label for="name">Jméno a příjmení</label>
              <input id="name" name="name" type="text" required />
            </div>
            <div>
              <label for="email">E-mail</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div>
              <label for="phone">Telefon</label>
              <input id="phone" name="phone" type="tel" />
            </div>
            <div>
              <label for="company">Firma</label>
              <input id="company" name="company" type="text" />
            </div>
            <div>
              <label for="message">Zpráva</label>
              <textarea id="message" name="message" rows="4"></textarea>
            </div>
            <button class="btn btn--primary" type="submit">Odeslat poptávku</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  label { display: block; font-weight: 600; color: var(--ink); margin-bottom: 6px; font-size: 0.95rem; }
  input, textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    font: inherit;
    color: var(--ink);
  }
  input:focus, textarea:focus { outline: 2px solid var(--brand); border-color: var(--brand); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
</style>
