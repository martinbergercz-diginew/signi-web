---
import Base from '../layouts/Base.astro';
---

<Base
  title="Kontakt | Signi"
  description="Chcete se na něco zeptat, nebo potřebujete pomoci s elektronickým podpisem? Kontaktujte naše specialisty na vybraná témata. Rádi pomůžeme. Tým Signi."
  lang="cs"
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">Kontakt</span>
      <h1>Kontaktujte nás</h1>
      <p class="lead">
        Chcete se na něco zeptat, nebo potřebujete pomoci s elektronickým
        podpisem? Ozvěte se — rádi pomůžeme.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <div class="card">
          <h3>Potřebujete poradit s provozem?</h3>
          <p>
            Pokud potřebujete pomoct s aplikací, kontaktujte nás přes chat,
            nebo na e-mailu <a href="mailto:help@signi.com">help@signi.com</a>.
          </p>
        </div>
        <div class="card">
          <h3>Hledáte informace o cenách a produktu Signi?</h3>
          <p>
            Ozvěte se našemu specialistovi na
            <a href="mailto:sales@signi.com">sales@signi.com</a>. Zjistíte, jak
            může Signi pomoct ve vaší firmě, a pošleme vám případové studie
            podobných firem.
          </p>
          <p><a class="btn btn--primary" href="/odeslat-poptavku/">Domluvit prezentaci</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="grid grid--2">
        <div>
          <h2>Kde máme kanceláře</h2>
          <p>Sokolovská 694/102a, Praha 8, 186 00 — vchod E</p>
          <p>
            Obecné dotazy: <a href="mailto:info@signi.com">info@signi.com</a><br />
            Obchodní oddělení: <a href="mailto:sales@signi.com">sales@signi.com</a><br />
            Podpora: <a href="mailto:help@signi.com">help@signi.com</a>
          </p>
        </div>
        <div>
          <h2>Fakturační údaje</h2>
          <dl class="dl">
            <dt>Společnost</dt>
            <dd>Digital factory s.r.o.</dd>
            <dt>Sídlo</dt>
            <dd>Sokolovská 694/102a, Praha 8, 186 00</dd>
            <dt>IČO</dt>
            <dd>06988377</dd>
            <dt>DIČ</dt>
            <dd>CZ06988377</dd>
          </dl>
        </div>
      </div>
    </div>
  </section>
</Base>
