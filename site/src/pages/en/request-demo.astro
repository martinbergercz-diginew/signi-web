---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Request a demo | Signi"
  description="Have a question? Leave us your contact details and a specialist in electronic signatures will get back to you shortly."
  lang="en"
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">Request a demo</span>
      <h1>You’re so close. Fill out the form and we’ll do the rest</h1>
      <p class="lead">
        Leave us your contact details and a specialist will contact you shortly.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <div>
          <h2>What you can expect from us</h2>
          <ul class="prose">
            <li>You will get information about pricing.</li>
            <li>Find out how Signi can help your business.</li>
            <li>We’ll send you case studies of companies like yours.</li>
            <li>We’ll calculate a price tailored to the size of your team.</li>
          </ul>
          <p>
            Don’t want to wait? Call us at <a href="tel:+420775797252">+420 775 797 252</a>,
            online 8 AM–6 PM.
          </p>
        </div>
        <div class="card">
          <form method="post" action="/api/forms" class="stack">
            <input type="hidden" name="form_type" value="request-demo" />
            <input type="hidden" name="lang" value="en" />
            {/* Honeypot — hidden from people, bots fill it and get silently dropped. */}
            <div class="hp" aria-hidden="true">
              <label for="website">Website</label>
              <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
            </div>
            <div>
              <label for="name">Full name</label>
              <input id="name" name="name" type="text" required />
            </div>
            <div>
              <label for="email">E-mail</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div>
              <label for="phone">Phone</label>
              <input id="phone" name="phone" type="tel" />
            </div>
            <div>
              <label for="company">Company</label>
              <input id="company" name="company" type="text" />
            </div>
            <div>
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="4"></textarea>
            </div>
            <button class="btn btn--primary" type="submit">Send request</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  label { display: block; font-weight: 600; color: var(--ink); margin-bottom: 6px; font-size: 0.95rem; }
  input, textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    font: inherit;
    color: var(--ink);
  }
  input:focus, textarea:focus { outline: 2px solid var(--brand); border-color: var(--brand); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
</style>
