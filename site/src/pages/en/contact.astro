---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Contact | Signi"
  description="Want to ask something or need help with electronic signatures? Contact our specialists — we’re happy to help."
  lang="en"
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">Contact</span>
      <h1>Contact us</h1>
      <p class="lead">
        Want to ask something or need help with electronic signatures? Get in
        touch — we’re happy to help.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <div class="card">
          <h3>Need help with running Signi?</h3>
          <p>
            If you need help with the app, contact us via chat or e-mail
            <a href="mailto:help@signi.com">help@signi.com</a>.
          </p>
        </div>
        <div class="card">
          <h3>Looking for pricing and product information?</h3>
          <p>
            Contact our specialist to find out how Signi can help your business.
            We’ll send you case studies of companies similar to yours.
          </p>
          <p><a class="btn btn--primary" href="/en/request-demo/">Request a demo</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="grid grid--2">
        <div>
          <h2>Our offices</h2>
          <p>Sokolovská 694/102a, Praha 8, 186 00, Czechia</p>
          <p>
            General enquiries: <a href="mailto:info@signi.com">info@signi.com</a><br />
            Sales: <a href="mailto:sales@signi.com">sales@signi.com</a><br />
            Support: <a href="mailto:help@signi.com">help@signi.com</a><br />
            Phone: <a href="tel:+420222260888">+420 222 260 888</a> (online 8 AM–6 PM)
          </p>
        </div>
        <div>
          <h2>Billing information</h2>
          <dl class="dl">
            <dt>Company</dt>
            <dd>Digital factory s.r.o.</dd>
            <dt>Registered office</dt>
            <dd>Sokolovská 694/102a, Praha 8, 186 00, Czech Republic</dd>
            <dt>CIN</dt>
            <dd>06988377</dd>
            <dt>TIN</dt>
            <dd>CZ06988377</dd>
          </dl>
        </div>
      </div>
    </div>
  </section>
</Base>
