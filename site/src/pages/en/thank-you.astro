---
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url.js';
---

<Base
  title="Thank you | Signi"
  description="We have received your message. Our specialist will get back to you shortly."
  lang="en"
>
  <section class="section">
    <div class="container narrow text-center" style="max-width:680px;margin:0 auto">
      <span class="eyebrow">Done</span>
      <h1>Thank you, we have your message</h1>
      <p class="lead">
        We have received your request. Our specialist will get back to you,
        usually by the next business day.
      </p>
      <div class="hero__actions" style="justify-content:center">
        <a class="btn btn--primary" href={url('/en/')}>Back to home</a>
        <a class="btn btn--ghost" href={url('/en/blog-2/')}>Read the blog</a>
      </div>
    </div>
  </section>
</Base>

{/* Fire the GTM conversion event — preserves the lead tracking the CF7
    thank-you pages drove on the old WordPress site. */}
<script is:inline>
  (function () {
    var form = new URLSearchParams(location.search).get('form') || 'contact';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'generate_lead', form_type: form });
  })();
</script>
