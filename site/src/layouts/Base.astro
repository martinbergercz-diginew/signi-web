---
interface Props {
  title: string;
  lang?: string;
}
const { title, lang = 'cs' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {/* GTM container GTM-WP6ZVZF is added here in Phase 5. */}
  </head>
  <body>
    <slot />
  </body>
</html>
